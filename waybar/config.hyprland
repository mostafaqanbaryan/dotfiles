{
    "layer": "top",
    "position": "left",
    "orientation": "vertical",

    "modules-left": ["hyprland/workspaces", "custom/media", "idle_inhibitor"],
    "modules-center": [],
    "modules-right": [
        "hyprland/submap",
        "tray",
        "hyprland/language",
        "custom/updates",
        "privacy",
        "memory",
        "load",
        "temperature",
        "battery",
        "group/group-audio",
        "power-profiles-daemon",
        "custom/notification",
        "group/group-icons",
        "clock",
        "custom/shamsi",
    ],

    "hyprland/workspaces": {
        "format": "<big>{icon}</big>",
        "format-icons": {
            "1": "",
            "2": "",
            "3": "",
            "4": "",
            "5": "",
            "10": "",
            "default": ""
        }
    },

    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>"
    },

    "idle_inhibitor": {
        "format": "<big>{icon}</big>",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        },
        "start-activated": false
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10
    },

    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "<big>{:%Y</big>\n%m-%d}",
        "format": "{:%H:%M<big>\n%OS}</big>",
        "justify": "center",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        },
        "interval": 1
    },

    "group/group-audio": {
        "orientation": "vertical",
        "drawer": {
            "transition-duration": 500,
            "children-class": "",
            "transition-left-to-right": false
        },
        "modules": [
            "pulseaudio",
            "pulseaudio/slider"
        ]
    },

    "pulseaudio/slider": {
        "orientation": "vertical"
    },

    "pulseaudio": {
        "format": "<small>{volume}</small> {icon}",
        "format-bluetooth": "<small>{volume}</small> {icon}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": "<small>0</small> {icon}",
        "format-source": "<small>{volume}</small> ",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "sleep 0.1 && pavucontrol"
    },

    "custom/power": {
        "format": "",
        "min-length": 3,
        "on-click": "sleep 0.1 && $HOME/.config/rofi/scripts/powermenu_t6"
    },

    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": " <span foreground='red'><sup></sup></span>",
            "none": "",
            "dnd-notification": " <span foreground='red'><sup></sup></span>",
            "dnd-none": "",
            "inhibited-notification": "<span foreground='red'><sup></sup></span>",
            "inhibited-none": "",
            "dnd-inhibited-notification": "<span foreground='red'><sup></sup></span>",
            "dnd-inhibited-none": ""
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "sleep 0.1 && swaync-client -d -sw",
        "escape": true
    },

    "custom/media": {
        "format": "{}",
        "return-type": "json",
        "max-length": 40,
        "rotate": 90,
        "on-click": "sleep 0.1 && playerctl play-pause",
        "on-scroll-up": "playerctl position 5+",
        "on-scroll-down": "playerctl position 5-",
        "format-icons": {
            "spotify": "",
            "default": "🎜"
        },
        "exec": "$HOME/.config/waybar/resources/./player.sh 2> /dev/null"
    },

    "custom/screenshot": {
        "format": "",
        "tooltip": false,
        "min-length": 3,
        "on-click": "sleep 0.1 && grim -g \"$(slurp)\" - | swappy -f -",
        "on-click-middle": "sleep 0.1 && grim -g \"$(swaymsg -t get_tree | jq -r '.. | select(.pid? and .visible?) | .rect | \"\\(.x),\\(.y) \\(.width)x\\(.height)\"' | slurp)\" - | swappy -f -"
    },

    "custom/colorpicker": {
        "format": "",
        "tooltip": false,
        "min-length": 4,
        "on-click": "hyprpicker -a"
    },

    "custom/shamsi": {
        "format": "{}",
        "tooltip": true,
        "justify": "center",
        "return-type": "json",
        "exec": "$HOME/.config/waybar/resources/shamsi.sh",
        "interval": 60
    },

    "custom/updates": {
        "format": "<small>{}</small> 󰚰",
        "exec": "checkupdates | wc -l",
        "interval": 600
    },

    "privacy": {
        "icon-spacing": 14,
        "icon-size": 18,
        "transition-duration": 250,
        "modules": [
            {
                "type": "screenshare",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-in",
                "tooltip": true,
                "tooltip-icon-size": 24
            }
        ]
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "min-length": 4,
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "",
            "performance": "",
            "balanced": "",
            "power-saver": ""
        }
    },

    "memory": {
        "interval": 30,
        "format": "<small>{}</small> 󰍛",
        "max-length": 6
    },

    "load": {
        "interval": 5,
        "format": "<small>{load1}</small>",
        "max-length": 1
    },

    "hyprland/language": {
        "on-click": "hyprctl switchxkblayout all next",
        "format-en": "ENG",
        "format-fa": "فارسی",
    },

    "group/group-icons": {
        "orientation": "vertical",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/power",
            "custom/colorpicker",
            "custom/screenshot",
        ]
    },

    "temperature": {
        "interval": 2,
        "justify": "center",
        "critical-threshold": 88,
        "format-critical": "!!!\n{temperatureC} \n!!!",
        "format": "<small>{temperatureC}</small> "
    }
}

